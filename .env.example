# Supabase (https://supabase.com/dashboard)
# Project Settings > API : Project URL et anon/public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase LOCAL (npx supabase start → copier URL et anon key affichés)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Firebase Authentication (Google, Apple, Email)
# Créez un projet sur https://console.firebase.google.com
# Activez Auth > Sign-in method : Google, Apple, Email/Password
# Récupérez la config dans Paramètres du projet > Vos applications

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase
# Créez un projet sur https://supabase.com
# Récupérez l'URL et la clé anon dans Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
